# Local development — copy to .env (never commit .env)

DATABASE_URL="postgresql://leanstock:leanstock@localhost:5432/leanstock"
REDIS_URL="redis://localhost:6379"

JWT_SECRET_KEY="change-this-to-a-long-random-string-in-production-32"
JWT_REFRESH_SECRET_KEY="change-this-to-another-long-random-string-production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM_ADDRESS="noreply@leanstock.com"

# Local
FRONTEND_URL="http://localhost:5173"
BACKEND_PORT=3000
FRONTEND_PORT=5173
PORT=3000
NODE_ENV=development
ENVIRONMENT=development
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

SEED_DEV_ADMIN=true
SEED_ADMIN_EMAIL=sabina.serzhan@narxoz.kz
SEED_ADMIN_PASSWORD=AdminPass123

TENANT_ID=1
DECAY_THRESHOLD_DAYS=30
DECAY_PERCENT=10
DECAY_MAX_PERCENT=50
RESERVATION_TTL_SECONDS=600

# --- DeployRocks: set in dashboard for semgasabe-leans-api (NOT from this file) ---
# PORT=3000
# NODE_ENV=production
# DATABASE_URL=<linked semgasabe-leans-db>
# REDIS_URL=<linked semgasabe-leans-redis>
# FRONTEND_URL=https://semgasabe-leans.kazi.rocks
# CORS_ORIGINS=https://semgasabe-leans.kazi.rocks,https://semgasabe-leans-api.kazi.rocks
# SEED_DEV_ADMIN=false
# Do NOT set SEMGASABE_LEANS_API_URL on frontend — build uses VITE_API_URL in Dockerfile
