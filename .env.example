# Copy to .env and fill in real values. Never commit .env to git.

# Database
DATABASE_URL="postgresql://leanstock:leanstock@localhost:5432/leanstock"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (min 32 characters) — supports JWT_SECRET_KEY or legacy JWT_SECRET
JWT_SECRET_KEY="change-this-to-a-long-random-string-in-production-32"
JWT_REFRESH_SECRET_KEY="change-this-to-another-long-random-string-production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# SMTP / Email
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_API_KEY=""
EMAIL_FROM_ADDRESS="noreply@leanstock.com"
FRONTEND_URL="http://localhost:5173"

# Server
BACKEND_PORT=3000
FRONTEND_PORT=5173
PORT=3000
NODE_ENV=development
ENVIRONMENT=development

# Multi-tenancy
TENANT_ID=1

# CORS (comma-separated, no wildcards in production)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Dead stock decay
DECAY_THRESHOLD_DAYS=30
DECAY_PERCENT=10
DECAY_MAX_PERCENT=50

# Reservations (seconds)
RESERVATION_TTL_SECONDS=600
