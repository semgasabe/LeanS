# Copy this file to .env and fill in real values
# NEVER commit the real .env file to git

# Database
DATABASE_URL="file:./dev.db"

# JWT - must be at least 32 characters long
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-this-to-another-long-random-string-in-production"

# Token expiry
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server
PORT=3000
NODE_ENV=development

# Multi-tenancy - identifies which tenant this instance serves (numeric ID)
TENANT_ID=1

# Redis (optional - rate limiting still works without it using memory)
REDIS_URL="redis://localhost:6379"

# CORS - comma-separated list of allowed origins (no wildcard in prod)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Dead stock decay settings (configurable - not hardcoded)
DECAY_THRESHOLD_DAYS=30    # items older than this get a discount
DECAY_PERCENT=10           # how much discount to apply each time
DECAY_MAX_PERCENT=50       # maximum discount cap
