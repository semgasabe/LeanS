generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum MovementType {
  IN
  SALE
  ADJUSTMENT
  DAMAGE
  TRANSFER_IN
  TRANSFER_OUT
}

enum OrderStatus {
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

// 🔥 НОВАЯ МОДЕЛЬ TENANT
model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  products  Product[]
  locations Location[]
  inventory Inventory[]
  auditLogs AuditLog[]
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  name                String
  role                Role      @default(STAFF)
  locationId          String?
  tenantId            Int
  emailVerified       Boolean   @default(false)
  verificationToken   String?   @unique
  verificationExpires DateTime?
  resetToken          String?   @unique
  resetExpires        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  location      Location?       @relation(fields: [locationId], references: [id])
  movements     StockMovement[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([verificationToken])
  @@index([resetToken])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String
  tenantId  Int
  createdAt DateTime @default(now())

  users     User[]
  inventory Inventory[]
  tenant    Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  tenantId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory          Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([sku])
}

model Inventory {
  id              String   @id @default(uuid())
  productId       String
  locationId      String
  tenantId        Int
  quantity        Int      @default(0)
  minQuantity     Int      @default(10)
  discountPct     Int      @default(0)
  daysInInventory Int      @default(0)
  lastRestockedAt DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product         @relation(fields: [productId], references: [id])
  location  Location        @relation(fields: [locationId], references: [id])
  movements StockMovement[]
  tenant    Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([productId, locationId])
  @@index([tenantId])
  @@index([locationId])
  @@index([daysInInventory])
}

model StockMovement {
  id          String       @id @default(uuid())
  inventoryId String
  tenantId    Int
  type        MovementType
  quantity    Int
  note        String?
  createdBy   String
  createdAt   DateTime     @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  user      User      @relation(fields: [createdBy], references: [id])

  @@index([inventoryId])
  @@index([tenantId, createdAt])
}

model PurchaseOrder {
  id         String      @id @default(uuid())
  tenantId   Int
  locationId String
  status     OrderStatus @default(PENDING)
  supplier   String
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items PurchaseOrderItem[]

  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

// 🔥 AUDIT LOG МОДЕЛЬ
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  Int
  userId    String
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
  @@index([tableName])
}
