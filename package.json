{
  "name": "leanstock-api",
  "version": "1.0.0",
  "description": "LeanStock Inventory Management API",
  "engines": {
    "node": ">=20"
  },
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src/ tests/ --max-warnings 0"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.6",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "swagger-ui-express": "^5.0.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
