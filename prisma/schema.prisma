generator client {
  provider = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum MovementType {
  IN
  SALE
  ADJUSTMENT
  DAMAGE
  TRANSFER_IN
  TRANSFER_OUT
}

enum OrderStatus {
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  role       Role     @default(STAFF)
  locationId String?
  tenantId   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location      Location?       @relation(fields: [locationId], references: [id])
  movements     StockMovement[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  emailVerified   Boolean   @default(false)
  verificationToken String?  @unique
  verificationExpires DateTime?
  resetToken      String?   @unique
  resetExpires    DateTime?

  @@index([tenantId])
  @@index([email])
}

// Stored refresh tokens for revocation support
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String
  tenantId  Int
  createdAt DateTime @default(now())

  users     User[]
  inventory Inventory[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  tenantId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory          Inventory[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([tenantId])
  @@index([sku])
}

model Inventory {
  id              String   @id @default(uuid())
  productId       String
  locationId      String
  tenantId        Int
  quantity        Int      @default(0)
  minQuantity     Int      @default(10)
  discountPct     Int      @default(0) // max 50 - dead stock decay
  daysInInventory Int      @default(0)
  lastRestockedAt DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product       @relation(fields: [productId], references: [id])
  location  Location      @relation(fields: [locationId], references: [id])
  movements StockMovement[]

  @@unique([productId, locationId]) // one record per product per location
  @@index([tenantId])
  @@index([locationId])
  @@index([daysInInventory]) // used by dead stock cron job
}

model StockMovement {
  id          String       @id @default(uuid())
  inventoryId String
  tenantId    Int
  type        MovementType
  quantity    Int
  note        String?
  createdBy   String
  createdAt   DateTime     @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  user      User      @relation(fields: [createdBy], references: [id])

  @@index([inventoryId])
  @@index([tenantId, createdAt])
}

model PurchaseOrder {
  id         String      @id @default(uuid())
  tenantId   Int
  locationId String
  status     OrderStatus @default(PENDING)
  supplier   String
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items PurchaseOrderItem[]

  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

// Append-only audit log
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  Int
  userId    String
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId])
}
